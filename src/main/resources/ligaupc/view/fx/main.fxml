<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    main.fxml - Ventana principal del sistema Liga UPC

    Estructura:
      BorderPane
        top    -> cabecera con titulo del sistema
        left   -> barra lateral de navegacion (VBox con botones por modulo)
        center -> area de contenido (StackPane) donde se cargan los modulos

    Patron GRASP Controller:
      MainController gestiona la navegacion: al hacer click en un boton
      de la barra lateral carga el FXML correspondiente en el contentArea.
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ligaupc.view.fx.MainController">

    <!-- ════════════════════════════════════════
         CABECERA
         ════════════════════════════════════════ -->
    <top>
        <HBox style="-fx-background-color: #1a237e; -fx-padding: 14 20; -fx-alignment: CENTER-LEFT;">
            <Label text="Liga UPC  —  Sistema de Gestion Futbol Universitario"
                   style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ════════════════════════════════════════
         BARRA LATERAL DE NAVEGACION
         ════════════════════════════════════════ -->
    <left>
        <VBox spacing="4"
              style="-fx-background-color: #283593; -fx-padding: 20 8 20 8; -fx-min-width: 170;">

            <!-- Etiqueta de seccion -->
            <Label text="MODULOS"
                   style="-fx-text-fill: #90caf9; -fx-font-size: 10;
                          -fx-font-weight: bold; -fx-padding: 0 0 8 6;"/>

            <!-- Botones de navegacion -->
            <Button fx:id="btnJugadores"
                    text="Jugadores"
                    onAction="#loadJugadores"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-alignment: CENTER-LEFT; -fx-padding: 9 14;
                           -fx-font-size: 13; -fx-cursor: hand;"/>

            <Button fx:id="btnTecnicos"
                    text="Tecnicos"
                    onAction="#loadTecnicos"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-alignment: CENTER-LEFT; -fx-padding: 9 14;
                           -fx-font-size: 13; -fx-cursor: hand;"/>

            <Button fx:id="btnArbitros"
                    text="Arbitros"
                    onAction="#loadArbitros"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-alignment: CENTER-LEFT; -fx-padding: 9 14;
                           -fx-font-size: 13; -fx-cursor: hand;"/>

            <Button fx:id="btnEquipos"
                    text="Equipos"
                    onAction="#loadEquipos"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-alignment: CENTER-LEFT; -fx-padding: 9 14;
                           -fx-font-size: 13; -fx-cursor: hand;"/>

            <Button fx:id="btnPartidos"
                    text="Partidos"
                    onAction="#loadPartidos"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-alignment: CENTER-LEFT; -fx-padding: 9 14;
                           -fx-font-size: 13; -fx-cursor: hand;"/>

            <Separator style="-fx-padding: 4 0;"/>

            <Button fx:id="btnEstadisticas"
                    text="Estadisticas"
                    onAction="#loadEstadisticas"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-alignment: CENTER-LEFT; -fx-padding: 9 14;
                           -fx-font-size: 13; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- ════════════════════════════════════════
         AREA DE CONTENIDO CENTRAL
         Se reemplaza en cada navegacion via MainController.loadModule()
         ════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #f5f5f5;">
            <!-- Vista de bienvenida visible al iniciar la aplicacion -->
            <VBox alignment="CENTER" spacing="14">
                <Label text="Bienvenido a Liga UPC"
                       style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
                <Label text="Seleccione un modulo en la barra lateral para comenzar."
                       style="-fx-font-size: 14; -fx-text-fill: #555;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
